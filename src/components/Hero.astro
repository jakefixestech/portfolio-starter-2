---
---

<section 
  class="relative text-white overflow-hidden"
  style="background-image: url('/sugarhouse.webp'); background-size: cover; background-position: center; background-color: rgb(120, 53, 15);"
>
  <div class="absolute inset-0 bg-amber-900/60"></div>

  <!-- Decorative falling leaves and buckets -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <defs>
        <!-- Maple leaf shape -->
        <path id="leaf" d="M0,-12 C2,-8 8,-8 6,-4 C9,-5 10,-2 7,0 C9,2 7,6 4,4 C4,7 2,9 0,12 C-2,9 -4,7 -4,4 C-7,6 -9,2 -7,0 C-10,-2 -9,-5 -6,-4 C-8,-8 -2,-8 0,-12Z" />
        <!-- Sap bucket shape -->
        <g id="bucket">
          <!-- handle -->
          <path d="M-5,-6 Q0,-10 5,-6" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          <!-- bucket body -->
          <path d="M-5,-5 L-6,6 Q0,8 6,6 L5,-5 Z" />
          <!-- rim -->
          <rect x="-5.5" y="-6" width="11" height="2" rx="0.5" />
          <!-- tap line -->
          <line x1="0" y1="-6" x2="0" y2="-10" stroke="currentColor" stroke-width="0.8"/>
        </g>

        <style>
          .leaf-1  { animation: fall1 14s linear infinite; animation-delay: 0s;    }
          .leaf-2  { animation: fall2 17s linear infinite; animation-delay: -4s;   }
          .leaf-3  { animation: fall1 12s linear infinite; animation-delay: -7s;   }
          .leaf-4  { animation: fall3 19s linear infinite; animation-delay: -2s;   }
          .leaf-5  { animation: fall2 15s linear infinite; animation-delay: -10s;  }
          .leaf-6  { animation: fall3 13s linear infinite; animation-delay: -5s;   }
          .leaf-7  { animation: fall1 18s linear infinite; animation-delay: -12s;  }
          .leaf-8  { animation: fall2 11s linear infinite; animation-delay: -8s;   }
          .bucket-1 { animation: fall4 20s linear infinite; animation-delay: -3s;  }
          .bucket-2 { animation: fall5 24s linear infinite; animation-delay: -14s; }
          .bucket-3 { animation: fall4 22s linear infinite; animation-delay: -9s;  }

          @keyframes fall1 {
            0%   { transform: translateY(-60px) rotate(0deg);   opacity: 0; }
            5%   { opacity: 1; }
            90%  { opacity: 0.7; }
            100% { transform: translateY(110vh) rotate(360deg); opacity: 0; }
          }
          @keyframes fall2 {
            0%   { transform: translateY(-60px) rotate(20deg)  translateX(0px);    opacity: 0; }
            5%   { opacity: 1; }
            40%  { transform: translateY(40vh)  rotate(200deg) translateX(30px);   opacity: 0.8; }
            90%  { opacity: 0.6; }
            100% { transform: translateY(110vh) rotate(400deg) translateX(-20px);  opacity: 0; }
          }
          @keyframes fall3 {
            0%   { transform: translateY(-60px) rotate(-15deg) translateX(0px);   opacity: 0; }
            5%   { opacity: 1; }
            50%  { transform: translateY(50vh)  rotate(180deg) translateX(-25px);  opacity: 0.9; }
            90%  { opacity: 0.5; }
            100% { transform: translateY(110vh) rotate(300deg) translateX(15px);   opacity: 0; }
          }
          @keyframes fall4 {
            0%   { transform: translateY(-80px) rotate(0deg);  opacity: 0; }
            5%   { opacity: 0.6; }
            90%  { opacity: 0.4; }
            100% { transform: translateY(110vh) rotate(20deg); opacity: 0; }
          }
          @keyframes fall5 {
            0%   { transform: translateY(-80px) rotate(5deg)  translateX(0px);   opacity: 0; }
            5%   { opacity: 0.5; }
            50%  { transform: translateY(50vh)  rotate(-5deg) translateX(-15px);  opacity: 0.4; }
            100% { transform: translateY(110vh) rotate(10deg) translateX(10px);   opacity: 0; }
          }
        </style>
      </defs>

      <!-- Leaves — scattered x positions across full width -->
      <use href="#leaf" class="leaf-1" x="8%"  y="0" fill="#c2410c" opacity="0.75" transform-origin="8%  0" />
      <use href="#leaf" class="leaf-2" x="22%" y="0" fill="#d97706" opacity="0.65" transform-origin="22% 0" />
      <use href="#leaf" class="leaf-3" x="38%" y="0" fill="#b45309" opacity="0.70" transform-origin="38% 0" />
      <use href="#leaf" class="leaf-4" x="55%" y="0" fill="#c2410c" opacity="0.60" transform-origin="55% 0" />
      <use href="#leaf" class="leaf-5" x="70%" y="0" fill="#d97706" opacity="0.75" transform-origin="70% 0" />
      <use href="#leaf" class="leaf-6" x="84%" y="0" fill="#b45309" opacity="0.65" transform-origin="84% 0" />
      <use href="#leaf" class="leaf-7" x="15%" y="0" fill="#d97706" opacity="0.55" transform-origin="15% 0" />
      <use href="#leaf" class="leaf-8" x="92%" y="0" fill="#c2410c" opacity="0.60" transform-origin="92% 0" />

      <!-- Buckets — fewer, slower, more subtle -->
      <use href="#bucket" class="bucket-1" x="18%" y="0" fill="#92400e" color="#92400e" opacity="0.45" transform-origin="18% 0" />
      <use href="#bucket" class="bucket-2" x="63%" y="0" fill="#78350f" color="#78350f" opacity="0.35" transform-origin="63% 0" />
      <use href="#bucket" class="bucket-3" x="82%" y="0" fill="#92400e" color="#92400e" opacity="0.40" transform-origin="82% 0" />
    </svg>
  </div>

  <div class="relative max-w-5xl mx-auto px-4 py-24 md:py-36 text-center">
    <img
      src="/logo.webp"
      alt="White Mountain Maple Co. vintage badge logo"
      class="mx-auto mb-6 w-40 md:w-52"
      width="208"
      height="208"
      loading="eager"
      decoding="async"
    />
    <h1 class="sr-only">White Mountain Maple Co.</h1>
    <p class="text-xl md:text-2xl mb-8 italic">
      Small Batch. Pure NH Maple.
    </p>
    <a 
      href="/products" 
      class="inline-block bg-cream text-amber-700 px-8 py-3 text-lg font-semibold hover:bg-amber-50 focus:outline-none focus:ring-2 focus:ring-cream focus:ring-offset-2 focus:ring-offset-amber-900"
    >
      Shop Our Maple
    </a>
  </div>
</section>