---
---

<section class="relative text-white overflow-hidden hero-section">
  <!-- Video background -->
  <div class="absolute inset-0">
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/sugarhouse.webp"
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden="true"
    >
      <source src="/hero-maple.mp4" type="video/mp4" />
    </video>
    <!-- Dark gradient overlay — strong enough to keep white text readable
         even over the bright sky in the middle of the clip -->
    <div class="absolute inset-0 hero-overlay" aria-hidden="true"></div>
  </div>

  <!-- Content -->
  <div class="relative max-w-5xl mx-auto px-4 py-24 md:py-36 text-center">
    <img
      src="/logo.webp"
      alt="White Mountain Maple Co. vintage badge logo"
      class="mx-auto mb-6 w-40 md:w-52"
      width="208"
      height="208"
      loading="eager"
      decoding="async"
    />
    <h1 class="sr-only">White Mountain Maple Co.</h1>
    <p class="text-xl md:text-2xl mb-8 italic hero-tagline">
      Small Batch. Pure NH Maple.
    </p>
    <a
      href="/products"
      class="inline-block bg-cream text-amber-700 px-8 py-3 text-lg font-semibold hover:bg-amber-50 focus:outline-none focus:ring-2 focus:ring-cream focus:ring-offset-2 focus:ring-offset-amber-900"
    >
      Shop Our Maple
    </a>
  </div>
</section>

<style>
  /* Dark fallback bg ensures WAVE computes contrast against dark
     (it can't see through the video element to know what's actually behind) */
  .hero-section {
    background-color: #1a0f0a;
  }

  /* Text shadow guarantees readability against any frame of the video
     and against the poster image fallback */
  .hero-tagline {
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.7);
  }

  /* Strong gradient: darker at top and bottom to anchor logo + CTA,
     warm amber tint throughout to keep brand consistency */
  .hero-overlay {
    background:
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.55) 0%,
        rgba(0, 0, 0, 0.35) 35%,
        rgba(0, 0, 0, 0.5) 65%,
        rgba(0, 0, 0, 0.7) 100%
      ),
      linear-gradient(
        to bottom,
        rgba(120, 53, 15, 0.35),
        rgba(120, 53, 15, 0.45)
      );
  }

  /* Respect reduced motion — pause video for users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    video {
      display: none;
    }
    .hero-section {
      background-image: url('/sugarhouse.webp');
      background-size: cover;
      background-position: center;
      background-color: rgb(120, 53, 15);
    }
  }
</style>