---
const currentYear = new Date().getFullYear();
---

<footer class="bg-amber-900 text-white">
  <div class="max-w-5xl mx-auto px-6 pt-12 pb-8">

    <!-- Top section: 3-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 mb-10">

      <!-- Column 1: Brand -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <a href="/" aria-label="White Mountain Maple Co. - Home" class="inline-block mb-4">
          <img
            src="/logo.webp"
            alt="White Mountain Maple Co. vintage badge logo"
            class="w-24 opacity-90 hover:opacity-100 transition-opacity"
            width="96"
            height="96"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="font-semibold text-white text-lg leading-snug">White Mountain Maple Co.</p>
        <p class="text-amber-200 text-sm mt-1">Littleton, New Hampshire</p>
        <p class="text-amber-300 text-sm mt-1">Est. 1973</p>
      </div>

      <!-- Column 2: Contact -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-white font-semibold text-sm uppercase tracking-widest mb-4">Contact Us</h2>
        <ul class="space-y-2">
          <li>
            <a href="tel:+16035550100" class="text-amber-200 text-sm hover:text-white transition-colors">
              (603) 555-0100
            </a>
          </li>
          <li>
            <a href="mailto:hello@example.com" class="text-amber-200 text-sm hover:text-white transition-colors">
              hello@example.com
            </a>
          </li>
          <li class="text-amber-200 text-sm pt-1">
            123 Sugar Maple Lane<br />Littleton, NH 03561
          </li>
        </ul>
      </div>

      <!-- Column 3: Hours -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-white font-semibold text-sm uppercase tracking-widest mb-4">Hours</h2>
        <ul class="space-y-1 text-sm text-amber-200">
          <li class="flex justify-center md:justify-start gap-4">
            <span class="w-28">Mon – Fri</span>
            <span>9am – 5pm</span>
          </li>
          <li class="flex justify-center md:justify-start gap-4">
            <span class="w-28">Saturday</span>
            <span>10am – 3pm</span>
          </li>
          <li class="flex justify-center md:justify-start gap-4">
            <span class="w-28">Sunday</span>
            <span>Closed</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Divider -->
    <hr class="border-amber-700 mb-6" />

    <!-- Bottom bar: nav + copyright -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap justify-center gap-6">
          <li><a href="/" class="text-sm text-amber-200 hover:text-white transition-colors">Home</a></li>
          <li><a href="/products" class="text-sm text-amber-200 hover:text-white transition-colors">Products</a></li>
          <li><a href="/contact" class="text-sm text-amber-200 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </nav>
      <p class="text-sm text-amber-300">&copy; {currentYear} White Mountain Maple Co. All rights reserved.</p>
    </div>

  </div>
</footer>