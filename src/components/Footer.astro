---
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/listings", label: "Listings" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const socialLinks = [
  { 
    href: "https://facebook.com", 
    label: "Facebook",
    icon: "facebook"
  },
  { 
    href: "https://instagram.com", 
    label: "Instagram",
    icon: "instagram"
  },
  { 
    href: "https://linkedin.com", 
    label: "LinkedIn",
    icon: "linkedin"
  },
];
---

<footer class="bg-navy-dark text-white" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Logo and Description -->
      <div class="lg:col-span-2">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-white font-heading font-bold text-xl hover:text-gold transition-colors"
          aria-label="North Country Realty Group - Home"
        >
          <svg class="w-8 h-8 text-gold" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20 4L4 16V36H16V24H24V36H36V16L20 4Z" fill="currentColor"/>
            <path d="M20 4L4 16V36H16V24H24V36H36V16L20 4Z" stroke="white" stroke-width="2" stroke-linejoin="round"/>
          </svg>
          North Country Realty Group
        </a>
        <p class="mt-4 text-gray-400 max-w-md">
          Your trusted real estate partner in Lancaster, NH and the surrounding North Country region. Helping families find their perfect home since 1999.
        </p>
        <div class="mt-6 flex items-center gap-4">
          {socialLinks.map((link) => (
            <a 
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-navy-light hover:bg-gold text-white hover:text-navy flex items-center justify-center transition-colors"
              aria-label={`Follow us on ${link.label}`}
            >
              {link.icon === "facebook" && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
                </svg>
              )}
              {link.icon === "instagram" && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                </svg>
              )}
              {link.icon === "linkedin" && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-heading font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-3" role="list">
          {navLinks.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-gray-400 hover:text-gold transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-heading font-semibold mb-4">Contact Us</h3>
        <address class="not-italic space-y-3 text-gray-400">
          <p class="flex items-start gap-3">
            <svg class="w-5 h-5 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>
              123 Main Street<br />
              Lancaster, NH 03584
            </span>
          </p>
          <p class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+16037881234" class="hover:text-gold transition-colors">
              (603) 788-1234
            </a>
          </p>
          <p class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@northcountryrealty.com" class="hover:text-gold transition-colors">
              info@northcountryrealty.com
            </a>
          </p>
        </address>
      </div>
    </div>

    <!-- Copyright and Legal Links -->
    <div class="mt-12 pt-8 border-t border-navy-light">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
        <p class="text-gray-500 text-sm">
          &copy; {currentYear} North Country Realty Group. All rights reserved.
        </p>
        <nav class="flex items-center gap-4" aria-label="Legal">
          <a 
            href="/privacy" 
            class="text-gray-500 hover:text-gold transition-colors text-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-navy-dark rounded"
          >
            Privacy Policy
          </a>
          <span class="text-gray-600" aria-hidden="true">|</span>
          <a 
            href="/terms" 
            class="text-gray-500 hover:text-gold transition-colors text-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-navy-dark rounded"
          >
            Terms of Service
          </a>
          <span class="text-gray-600" aria-hidden="true">|</span>
          <a 
            href="/accessibility" 
            class="text-gray-500 hover:text-gold transition-colors text-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-navy-dark rounded"
          >
            Accessibility
          </a>
        </nav>
      </div>
    </div>
  </div>
</footer>
