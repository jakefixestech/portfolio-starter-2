---
const currentYear = new Date().getFullYear();
---

<footer class="bg-amber-700 text-white">
  <div class="max-w-5xl mx-auto px-4 py-10 text-center">
    <a href="/" class="inline-block mb-4" aria-label="White Mountain Maple Co. - Home">
      <img
        src="/logo.webp"
        alt="White Mountain Maple Co. vintage badge logo"
        class="mx-auto w-28 md:w-32 opacity-90 hover:opacity-100 transition-opacity"
        width="128"
        height="128"
        loading="lazy"
        decoding="async"
      />
    </a>
    <p class="text-amber-100 mb-6">Littleton, New Hampshire</p>
    <nav aria-label="Footer navigation">
      <ul class="flex flex-wrap justify-center gap-6 mb-6">
        <li><a href="/products" class="text-sm text-amber-100 hover:text-white transition-colors">Products</a></li>
        <li><a href="/contact" class="text-sm text-amber-100 hover:text-white transition-colors">Contact</a></li>
      </ul>
    </nav>
    <p class="text-sm text-amber-200">&copy; {currentYear} White Mountain Maple Co. All rights reserved.</p>
  </div>
</footer>