---
---

<section class="bg-cream py-16 md:py-24">
  <div class="max-w-4xl mx-auto px-4">
    <div class="grid gap-8 md:grid-cols-2">
      <!-- Phone -->
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-12 h-12 bg-amber-700/10 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <div>
          <h2 class="font-serif text-xl text-amber-900 mb-1">Phone</h2>
          <a href="tel:+16035550187" class="font-serif text-amber-700 hover:underline">(603) 555-0187</a>
        </div>
      </div>

      <!-- Email -->
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-12 h-12 bg-amber-700/10 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <div>
          <h2 class="font-serif text-xl text-amber-900 mb-1">Email</h2>
          <a href="mailto:info@wmmapleco.example.com" class="font-serif text-amber-700 hover:underline break-all">info@wmmapleco.example.com</a>
        </div>
      </div>

      <!-- Hours -->
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-12 h-12 bg-amber-700/10 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h2 class="font-serif text-xl text-amber-900 mb-1">Hours</h2>
          <ul class="font-serif text-amber-800 space-y-1">
            <li>Monday - Friday: 9am - 5pm</li>
            <li>Saturday: 9am - 2pm</li>
            <li>Sunday: Closed</li>
          </ul>
        </div>
      </div>

      <!-- Farmers Market -->
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-12 h-12 bg-amber-700/10 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-amber-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <div>
          <h2 class="font-serif text-xl text-amber-900 mb-1">Find Us In Person</h2>
          <p class="font-serif text-amber-800">Visit us at the Littleton Farmers Market seasonally. Check our social media for weekly updates on market days.</p>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-amber-700/20 text-center">
      <p class="font-serif text-amber-800 max-w-2xl mx-auto">
        Located in the heart of the White Mountains in Littleton, New Hampshire. We welcome phone orders and are always happy to answer questions about our maple products.
      </p>
    </div>
  </div>
</section>