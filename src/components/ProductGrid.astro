---
const products = [
  {
    name: "Grade A Golden Delicate",
    description: "Our lightest syrup with a subtle, delicate flavor. Perfect for drizzling over vanilla ice cream or adding a gentle sweetness to tea. Harvested early in the season when the sap runs clearest.",
    image: "/maple-golden.jpg",
    alt: "Bottle of light golden maple syrup on a rustic wooden surface with wildflowers",
    bg: "bg-cream",
    reverse: false
  },
  {
    name: "Grade A Amber Rich",
    description: "A well-balanced maple flavor that's our most popular choice. Ideal for pancakes, waffles, and everyday use. The classic New Hampshire maple experience in every pour.",
    image: "/maple-amber.jpg",
    alt: "Amber maple syrup pouring over a stack of pancakes in a cozy farmhouse kitchen",
    bg: "bg-amber-50",
    reverse: true
  },
  {
    name: "Grade A Dark Robust",
    description: "Bold, full-bodied maple taste with hints of caramel. Excellent for baking and cooking, or for those who love a stronger flavor. Harvested late in the season for maximum depth.",
    image: "/maple-dark.jpg",
    alt: "Dark robust maple syrup bottle surrounded by cinnamon sticks and autumn maple leaves",
    bg: "bg-cream",
    reverse: false
  },
  {
    name: "Maple Cream",
    description: "Pure maple syrup whipped into a smooth, spreadable cream. A decadent treat on toast, muffins, or eaten straight from the jar. Once you try it you'll never go back.",
    image: "/maple-cream.jpg",
    alt: "Jar of maple cream spread on fresh bread on a wooden cutting board",
    bg: "bg-amber-50",
    reverse: true
  },
  {
    name: "Maple Sugar",
    description: "Crystallized pure maple, perfect for baking or as a natural sweetener. A wonderful substitute for refined sugar with a rich depth of flavor that plain sugar can never match.",
    image: "/maple-sugar.jpg",
    alt: "Wooden bowl filled with golden maple sugar crystals in warm light",
    bg: "bg-cream",
    reverse: false
  },
  {
    name: "Gift Boxes",
    description: "Curated collections of our finest products, beautifully packaged in rustic wooden crates with kraft paper and twine. The perfect way to share a true taste of New Hampshire with someone you love.",
    image: "/maple-gift.jpg",
    alt: "Rustic wooden gift crate filled with maple syrup bottles and maple products",
    bg: "bg-amber-50",
    reverse: true
  }
];
---

<div>
  {products.map((product) => (
    <section class={`${product.bg} py-16 md:py-20`}>
      <div class="max-w-6xl mx-auto px-6">
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${product.reverse ? 'lg:flex lg:flex-row-reverse' : ''}`}>

          <!-- Image -->
          <div>
            <img
              src={product.image}
              alt={product.alt}
              class="rounded-xl shadow-lg w-full object-cover"
              style="max-height: 520px;"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- Text -->
          <div class={product.reverse ? 'lg:pr-8' : 'lg:pl-8'}>
            <h2 class="font-serif text-3xl md:text-4xl text-amber-900 mb-6">
              {product.name}
            </h2>
            <p class="font-serif text-lg text-amber-800 leading-relaxed mb-8">
              {product.description}
            </p>
            <a
              href="/contact"
              class="inline-flex items-center gap-2 bg-amber-700 text-white font-serif font-semibold px-6 py-3 rounded-lg hover:bg-amber-800 transition-colors"
            >
              Order Now
              <svg style="height:1rem;width:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

        </div>
      </div>
    </section>
  ))}
</div>