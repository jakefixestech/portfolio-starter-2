---
const products = [
  {
    name: "Grade A Golden Delicate",
    description: "Our lightest syrup with a subtle, delicate flavor. Perfect for drizzling over vanilla ice cream or adding a gentle sweetness to tea.",
    icon: "golden"
  },
  {
    name: "Grade A Amber Rich",
    description: "A well-balanced maple flavor that's our most popular choice. Ideal for pancakes, waffles, and everyday use.",
    icon: "amber"
  },
  {
    name: "Grade A Dark Robust",
    description: "Bold, full-bodied maple taste with hints of caramel. Excellent for baking and cooking, or for those who love a stronger flavor.",
    icon: "dark"
  },
  {
    name: "Maple Cream",
    description: "Pure maple syrup whipped into a smooth, spreadable cream. A decadent treat on toast, muffins, or eaten straight from the jar.",
    icon: "cream"
  },
  {
    name: "Maple Sugar",
    description: "Crystallized pure maple, perfect for baking or as a natural sweetener. A wonderful substitute for refined sugar.",
    icon: "sugar"
  },
  {
    name: "Gift Boxes",
    description: "Curated collections of our finest products, beautifully packaged. The perfect way to share a taste of New Hampshire.",
    icon: "gift"
  }
];
---

<section class="bg-cream py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {products.map((product) => (
        <article class="bg-white border border-amber-200 rounded-lg p-6 flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-4 flex items-center justify-center">
            {product.icon === "golden" && (
              <svg viewBox="0 0 64 64" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="32" r="28" fill="#FDE68A" stroke="#CA8A04" stroke-width="2"/>
                <path d="M32 16C32 16 24 24 24 32C24 40 28 44 32 48C36 44 40 40 40 32C40 24 32 16 32 16Z" fill="#CA8A04"/>
              </svg>
            )}
            {product.icon === "amber" && (
              <svg viewBox="0 0 64 64" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="32" r="28" fill="#FCD34D" stroke="#B45309" stroke-width="2"/>
                <path d="M32 16C32 16 24 24 24 32C24 40 28 44 32 48C36 44 40 40 40 32C40 24 32 16 32 16Z" fill="#B45309"/>
              </svg>
            )}
            {product.icon === "dark" && (
              <svg viewBox="0 0 64 64" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="32" cy="32" r="28" fill="#D97706" stroke="#78350F" stroke-width="2"/>
                <path d="M32 16C32 16 24 24 24 32C24 40 28 44 32 48C36 44 40 40 40 32C40 24 32 16 32 16Z" fill="#78350F"/>
              </svg>
            )}
            {product.icon === "cream" && (
              <svg viewBox="0 0 64 64" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="12" y="20" width="40" height="28" rx="4" fill="#FEF3C7" stroke="#B45309" stroke-width="2"/>
                <path d="M16 28H48M16 36H48" stroke="#B45309" stroke-width="1.5"/>
                <rect x="20" y="14" width="24" height="8" rx="2" fill="#B45309"/>
              </svg>
            )}
            {product.icon === "sugar" && (
              <svg viewBox="0 0 64 64" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 48L16 24H48L44 48H20Z" fill="#FEF3C7" stroke="#B45309" stroke-width="2"/>
                <ellipse cx="32" cy="24" rx="16" ry="6" fill="#FEF3C7" stroke="#B45309" stroke-width="2"/>
                <circle cx="26" cy="34" r="2" fill="#B45309"/>
                <circle cx="34" cy="38" r="2" fill="#B45309"/>
                <circle cx="30" cy="42" r="2" fill="#B45309"/>
              </svg>
            )}
            {product.icon === "gift" && (
              <svg viewBox="0 0 64 64" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="12" y="28" width="40" height="24" rx="2" fill="#FEF3C7" stroke="#B45309" stroke-width="2"/>
                <rect x="10" y="20" width="44" height="10" rx="2" fill="#B45309"/>
                <path d="M32 20V52" stroke="#B45309" stroke-width="3"/>
                <path d="M32 20C32 20 24 14 20 16C16 18 18 24 24 24C28 24 32 20 32 20Z" fill="#B45309"/>
                <path d="M32 20C32 20 40 14 44 16C48 18 46 24 40 24C36 24 32 20 32 20Z" fill="#B45309"/>
              </svg>
            )}
          </div>
          <h2 class="font-serif text-xl text-amber-900 mb-3">{product.name}</h2>
          <p class="font-serif text-amber-800 leading-relaxed">{product.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>