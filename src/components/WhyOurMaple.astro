---
const features = [
  {
    title: '100% Pure NH Maple',
    description: 'Nothing added, nothing removed. Just pure maple goodness from our New Hampshire sugar bush.',
    icon: 'maple-leaf',
  },
  {
    title: 'Small Batch Wood-Fired',
    description: 'We fire our evaporator with local hardwood, giving our syrup its distinctive rich flavor.',
    icon: 'fire',
  },
  {
    title: 'Family Owned & Operated',
    description: 'Three generations of maple makers, dedicated to crafting the finest syrup possible.',
    icon: 'family',
  },
];
---

<section class="bg-amber-700/10">
  <div class="max-w-5xl mx-auto px-4 py-16 md:py-20">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-amber-700">
      Why Our Maple
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {features.map((feature) => (
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-4 flex items-center justify-center">
            {feature.icon === 'maple-leaf' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-amber-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22V12" />
                <path d="M12 12C12 12 8 9 5 9C5 9 6 12 6 14C6 14 4 13 2 13C2 13 4 16 6 17C6 17 4 18 3 20C3 20 7 19 9 17C9 17 10 20 12 22" />
                <path d="M12 12C12 12 16 9 19 9C19 9 18 12 18 14C18 14 20 13 22 13C22 13 20 16 18 17C18 17 20 18 21 20C21 20 17 19 15 17C15 17 14 20 12 22" />
                <path d="M12 12C12 12 12 6 12 2" />
              </svg>
            )}
            {feature.icon === 'fire' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-amber-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z" />
              </svg>
            )}
            {feature.icon === 'family' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-14 h-14 text-amber-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="7" r="3" />
                <circle cx="17" cy="7" r="2" />
                <path d="M9 10a5 5 0 0 0-5 5v4h10v-4a5 5 0 0 0-5-5z" />
                <path d="M17 9a3 3 0 0 1 3 3v7h-6" />
              </svg>
            )}
          </div>
          <h3 class="text-xl font-bold mb-2 text-amber-700">{feature.title}</h3>
          <p class="text-amber-700/80 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>