---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const ogImage = 'https://starter2.jakefixestech.com/sugarhouse.jpg';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="White Mountain Maple Co. - Small Batch Pure NH Maple Syrup from Littleton, NH" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-cream text-amber-700 font-serif">
    <slot />
  </body>
</html>