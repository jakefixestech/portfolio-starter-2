---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Granite State Plumbing & Drain - Professional plumbing services in Littleton, NH and the North Country. Licensed, insured, and locally trusted." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Granite State Plumbing & Drain</title>
  </head>
  <body class="min-h-screen bg-white text-navy-900 font-sans">
    <!-- Header -->
    <header class="bg-navy-900 text-white">
      <div class="max-w-6xl mx-auto px-4 py-4">
        <nav aria-label="Main navigation" class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <a href="/" aria-label="Granite State Plumbing & Drain - Home" class="text-xl font-bold">
            Granite State Plumbing & Drain
          </a>
          <ul class="flex gap-6 text-sm font-medium">
            <li>
              <a 
                href="/" 
                aria-label="Home"
                class:list={[
                  "hover:text-navy-200",
                  { "text-navy-200 underline underline-offset-4": currentPath === "/" }
                ]}
              >
                Home
              </a>
            </li>
            <li>
              <a 
                href="/services" 
                class:list={[
                  "hover:text-navy-200",
                  { "text-navy-200 underline underline-offset-4": currentPath === "/services" }
                ]}
              >
                Services
              </a>
            </li>
            <li>
              <a 
                href="/contact" 
                class:list={[
                  "hover:text-navy-200",
                  { "text-navy-200 underline underline-offset-4": currentPath === "/contact" }
                ]}
              >
                Contact
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-navy-900 text-white mt-16">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row md:justify-between gap-6">
          <div>
            <span class="font-bold text-lg">Granite State Plumbing & Drain</span>
            <p class="text-navy-200 text-sm mt-1">Littleton, NH</p>
          </div>
          <div class="text-sm text-navy-200">
            <p>(603) 555-0100</p>
            <p>granite@example.com</p>
          </div>
          <div class="text-sm text-navy-200">
            <p>Mon–Fri: 7am–5pm</p>
            <p>Sat: 8am–12pm</p>
            <p>Sun: Closed</p>
          </div>
        </div>
        <div class="border-t border-navy-700 mt-6 pt-6 text-center text-sm text-navy-300">
          <p>&copy; {new Date().getFullYear()} Granite State Plumbing & Drain. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }
</style>